{
  "name": "aidlc-main",
  "description": "Software development agent with structured workflow guidance",
  "prompt": "file://./prompts/aidlc-main.md",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y", 
        "@upstash/context7-mcp", 
        "--api-key", 
        "ctx7sk-22929cff-b314-44b0-8cb6-4fcca3156612"
      ],
      "env": {},
      "disabled": false
    },
    "aws-knowledge-mcp-server": {
      "url": "https://knowledge-mcp.global.api.aws",
      "type": "http",
      "disabled": false
    }
  },
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "web_*",
    "@context7",
    "@aws-knowledge-mcp-server"
  ],
  "resources": [
    "file://.kiro/steering/aws-aidlc-rules/core-workflow.md",
    "skill://.kiro/skills/*/SKILL.md"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": ["research-agent"],
      "trustedAgents": ["research-agent"]
    }
  },
  "includeMcpJson": false,
  "model": "claude-opus-4.6"
}
